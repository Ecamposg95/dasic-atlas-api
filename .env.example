# PostgreSQL (local)
# Recomendado: crear una base dedicada (ej. dasic_crm)
DATABASE_URL=postgresql+psycopg://postgres:toor@localhost:5432/dasi_crm_local

# JWT
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
TOKEN_COOKIE_NAME=access_token
COOKIE_SECURE=false

# Banxico (opcional). Token gratis tras registro en
# https://www.banxico.org.mx/SieAPIRest/service/v1/token/registro
# Si falta, /api/fx/usd-mxn cae a open.er-api.com (sin token).
BANXICO_TOKEN=

{
  "name": "dasic-atlas-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend assets pipeline for Dasic_Atlas_api (Tailwind compiled, no CDN)",
  "scripts": {
    "build:css": "tailwindcss -i ./app/static/css/input.css -o ./app/static/css/app.css --minify",
